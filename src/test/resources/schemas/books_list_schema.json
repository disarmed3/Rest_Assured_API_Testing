{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id","title","description","pageCount","excerpt","publishDate"],
    "properties": {
      "id": {
        "type": "integer"
      },
      "title": {
        "type": ["string","null"]
      },
      "description": {
        "type": ["string","null"]
      },
      "pageCount": {
        "type": "integer"
      },
      "excerpt": {
        "type": ["string","null"]
      },
      "publishDate": {
        "type": "string",
        "format": "date-time"
      }
    },
    "additionalProperties": false
  }
}
